<!doctype html>
{%- liquid
  assign color_mode_attr = 'light'
  if settings.color_scheme_mode == 'dark'
    assign color_mode_attr = 'dark'
  elsif settings.color_scheme_mode == 'system'
    assign color_mode_attr = 'system'
  endif

  assign html_classes = 'no-js'
  if settings.buttons_uppercase
    assign html_classes = html_classes | append: ' buttons-uppercase'
  endif
  if settings.button_shadow
    assign html_classes = html_classes | append: ' button-shadow'
  endif
-%}
<html class="{{ html_classes }}" lang="{{ request.locale.iso_code }}" data-color-mode="{{ color_mode_attr }}">
  <head>
    {%- render 'color-mode-script' -%}

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- render 'meta-tags' -%}

    {{ content_for_header }}

    {%- render 'theme-assets' -%}
  </head>

  <body>
    {%- render 'icon-sprite' -%}

    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip_to_text' | t }}</a>

    <div id="AtelierAnnouncer" class="visually-hidden" aria-live="polite" aria-atomic="true"></div>
    <div id="AtelierToast" class="toast-container"></div>
    <div id="AtelierLoadingBar" class="loading-bar" aria-hidden="true" data-loading-bar></div>

    {% sections 'header-group' %}

    <main id="MainContent" class="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {%- if settings.enable_age_verification -%}
      {% render 'age-verification' %}
    {%- endif -%}
    {%- if settings.enable_cookie_banner -%}
      {% render 'cookie-banner' %}
    {%- endif -%}
    {%- if settings.enable_popup -%}
      {% render 'email-popup' %}
    {%- endif -%}
  </body>
</html>
