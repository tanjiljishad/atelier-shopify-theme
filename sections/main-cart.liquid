<section class="section">
  <div class="page-width">
    <h1>{{ 'general.cart' | t }}</h1>

    {% if cart.empty? %}
      <p>Your cart is empty.</p>
      <a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    {% else %}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <a href="{{ item.url }}">
                {% if item.image %}
                  {{ item.image | image_url: width: 240 | image_tag: widths: '120, 180, 240', alt: item.image.alt }}
                {% endif %}
              </a>
              <div>
                <a href="{{ item.url }}">{{ item.product.title }}</a>
                <p>{{ item.final_line_price | money }}</p>
                <input class="quantity-input" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="cart-summary">
          <p><strong>Subtotal:</strong> {{ cart.total_price | money }}</p>
          <button class="button button--secondary" type="submit" name="update">Update cart</button>
          <button class="button" type="submit" name="checkout">Checkout</button>
        </div>
      </form>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
