{%- comment -%}
  Collection product grid (spec §8) — toolbar, filters (desktop sidebar /
  mobile drawer, same DOM node repositioned via CSS, not duplicated), product
  grid built on snippets/product-card.liquid, pagination, empty state.

  #FacetFiltersForm exists exactly once: <theme-drawer id="FilterDrawer">
  (Milestone 3's generic drawer, reused as-is) wraps the real filter form:
  on mobile it behaves as the standard off-canvas drawer; on desktop, CSS
  neutralizes the fixed/overlay/transform rules and renders the same node as
  a plain static sidebar (see .collection-filters-panel--sidebar in
  theme.css) — one real form, no second copy with duplicate ids or inert
  placeholder inputs.

  Works with zero JS: every checkbox/select is a real, named form control,
  and the form's native GET submission already filters/sorts correctly.
  assets/collection-filters.js progressively enhances this into instant-apply
  (Section Rendering API fetch + swap + history.pushState), matching the
  same pattern predictive-search.js established in Milestone 3.
{%- endcomment -%}
{% paginate collection.products by section.settings.products_per_page %}
  {%- liquid
    assign active_filter_count = 0
    for filter in collection.filters
      assign active_filter_count = active_filter_count | plus: filter.active_values.size
    endfor
    assign has_active_filters = false
    if active_filter_count > 0
      assign has_active_filters = true
    endif
  -%}
  <div id="CollectionSection" class="section section--rhythm" data-collection-section data-section-id="{{ section.id }}">
    <div class="container container--wide collection-layout">
      <theme-drawer
        id="FilterDrawer"
        side="left"
        class="collection-filters-panel{% if section.settings.desktop_filter_style == 'sidebar' %} collection-filters-panel--sidebar{% endif %}"
        hidden
      >
        <div class="drawer__scrim" data-drawer-dismiss></div>
        <div class="drawer__panel collection-filters-panel__panel" role="dialog" aria-modal="true" aria-label="{{ 'collections.filters.filter' | t }}">
          <div class="collection-filters-panel__header">
            <h2 class="collection-filters-panel__title">{{ 'collections.filters.filter' | t }}</h2>
            <button type="button" class="btn-icon" data-drawer-close aria-label="{{ 'general.close' | t }}">
              {% render 'icon', name: 'plus', class: 'icon--rotate-45' %}
            </button>
          </div>

          <form id="FacetFiltersForm" method="get" action="{{ collection.url }}" class="collection-filters-panel__form">
            {% render 'collection-filters', collection: collection %}
          </form>

          <div class="collection-filters-panel__footer">
            <button type="submit" form="FacetFiltersForm" class="btn btn--primary collection-filters-panel__submit">
              <span class="btn__label">{{ 'collections.filters.show_results' | t: count: paginate.items }}</span>
            </button>
          </div>
        </div>
      </theme-drawer>

      <div class="collection-layout__main">
        {% render 'collection-toolbar', collection: collection, results_count: paginate.items %}
        {% render 'active-filters', collection: collection %}

        {%- if collection.products.size > 0 -%}
          <div
            class="grid product-grid"
            data-collection-grid
            data-grid-cols="{{ section.settings.default_columns }}"
            style="--grid-columns: {{ section.settings.default_columns }};"
            data-scroll-reveal
          >
            {%- for product in collection.products -%}
              <div class="product-grid__item" data-scroll-reveal-child>
                {% render 'product-card', product: product, priority: forloop.index0 < 4 %}
              </div>
              {%- if section.settings.enable_editorial_tiles and section.blocks.size > 0 -%}
                {%- assign tile_position = forloop.index | modulo: 8 -%}
                {%- if tile_position == 0 -%}
                  {%- assign tile_cycle = forloop.index | divided_by: 8 | minus: 1 -%}
                  {%- assign tile_index = tile_cycle | modulo: section.blocks.size -%}
                  {%- assign tile = section.blocks[tile_index] -%}
                  <div class="product-grid__item product-grid__item--editorial" {{ tile.shopify_attributes }}>
                    <a href="{{ tile.settings.url }}" class="editorial-tile aspect-ratio">
                      {% render 'responsive-image', image: tile.settings.image, wrap: false, sizes: '25vw', class: 'editorial-tile__image' %}
                      {%- if tile.settings.heading != blank -%}
                        <span class="editorial-tile__heading color-scheme-scheme-2">{{ tile.settings.heading }}</span>
                      {%- endif -%}
                    </a>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>

          {% render 'pagination', paginate: paginate, style: section.settings.pagination_style %}
        {%- else -%}
          {% render 'collection-empty-state', has_active_filters: has_active_filters %}
        {%- endif -%}
      </div>
    </div>
  </div>
{% endpaginate %}

{% schema %}
{
  "name": "Collection grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "select",
      "id": "default_columns",
      "label": "Default columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "desktop_filter_style",
      "label": "Filter style (desktop)",
      "options": [
        { "value": "sidebar", "label": "Sidebar" },
        { "value": "drawer", "label": "Drawer" }
      ],
      "default": "sidebar",
      "info": "Mobile always uses a drawer regardless of this setting."
    },
    {
      "type": "select",
      "id": "pagination_style",
      "label": "Pagination style",
      "options": [
        { "value": "load_more", "label": "Load more button" },
        { "value": "numbered", "label": "Numbered pages" }
      ],
      "default": "load_more"
    },
    {
      "type": "checkbox",
      "id": "enable_editorial_tiles",
      "label": "Show editorial tiles in grid",
      "default": false,
      "info": "Inserts one image tile every 8 products, cycling through the blocks below."
    }
  ],
  "blocks": [
    {
      "type": "editorial_tile",
      "name": "Editorial tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
