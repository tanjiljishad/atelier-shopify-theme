{%- comment -%}
  Contact page. Uses Shopify's native `contact` form — no custom form
  handler, spam handling, or email delivery to build/maintain. Store info
  and social links now read the global "Store info & social" settings
  (Milestone 11) via social-links.liquid/store-info.liquid, the same two
  snippets footer.liquid's contact/social blocks use — a merchant enters
  each value once, correct everywhere. Originally section-scoped duplicates
  when this page was built in Milestone 10, before the footer existed to
  need the same data.

  Assigned via the "page.contact" alternate template in the Shopify admin
  (any page can use it), same OS 2.0 mechanism as any other alternate page
  template.
{%- endcomment -%}
<div class="container contact-page">
  <div class="contact-page__layout">
    <div class="contact-page__form-col">
      <h1 class="contact-page__title">{{ page.title }}</h1>
      {%- if page.content != blank -%}
        <div class="prose">{{ page.content }}</div>
      {%- endif -%}

      {%- form 'contact', class: 'customer-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="field__message field__message--success" role="status">{{ 'contact.success' | t }}</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="field__message field__message--error" role="alert">{{ form.errors.messages.first }}</p>
        {%- endif -%}

        <div class="customer-form__row">
          {% render 'field', id: 'ContactName', name: 'contact[name]', label: 'contact.name' | t, value: form.name, autocomplete: 'name', required: true %}
          {% render 'field', id: 'ContactEmail', name: 'contact[email]', type: 'email', label: 'contact.email' | t, value: form.email, autocomplete: 'email', required: true %}
        </div>
        {% render 'field', id: 'ContactPhone', name: 'contact[phone]', type: 'tel', label: 'contact.phone' | t, value: form.phone, autocomplete: 'tel' %}
        {% render 'field', id: 'ContactMessage', name: 'contact[body]', type: 'textarea', label: 'contact.message' | t, value: form.body, rows: 6, required: true %}

        <button type="submit" class="btn btn--primary">{{ 'contact.submit' | t }}</button>
      {%- endform -%}
    </div>

    <div class="contact-page__info-col">
      {%- if section.settings.show_map_placeholder -%}
        <div class="contact-page__map" role="img" aria-label="{{ 'contact.map_label' | t }}">
          {% render 'icon', name: 'map-pin', size: 32 %}
        </div>
      {%- endif -%}

      {% render 'store-info' %}
      {% render 'social-links' %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_map_placeholder",
      "label": "Show map placeholder",
      "default": false
    }
  ]
}
{% endschema %}
