{%- comment -%}
  Maintenance / password page (spec §5.6: "full-bleed brand image + centered
  logo, Marcellus one-liner, password input; newsletter capture optional").
  Newsletter capture reuses sections/newsletter.liquid verbatim via the
  `{% section %}` tag rather than a second copy of that form — same
  `contact[tags]=newsletter` customer-form pattern, same settings.

  Uses Shopify's native `storefront_password` form — the only form type that
  can actually unlock a password-protected store.
{%- endcomment -%}
<div class="password-page">
  {%- if section.settings.background_image != blank -%}
    <div class="password-page__media" aria-hidden="true">
      {% render 'responsive-image', image: section.settings.background_image, sizes: '100vw', wrap: false, priority: true, class: 'password-page__image' %}
      <span class="password-page__scrim"></span>
    </div>
  {%- endif -%}

  <div class="password-page__content color-scheme-scheme-2">
    {%- if section.settings.logo != blank -%}
      {% render 'responsive-image', image: section.settings.logo, sizes: '160px', wrap: false, class: 'password-page__logo', priority: true %}
    {%- else -%}
      <span class="password-page__logo-text">{{ shop.name }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <p class="password-page__heading">{{ section.settings.heading }}</p>
    {%- endif -%}

    {%- form 'storefront_password', class: 'password-page__form' -%}
      <div class="field__control">
        <input
          type="password"
          name="password"
          class="field__input"
          placeholder="{{ 'general.password.placeholder' | t }}"
          aria-label="{{ 'general.password.placeholder' | t }}"
          required
        >
      </div>
      <button type="submit" class="btn btn--primary">{{ 'general.password.enter' | t }}</button>
      {%- if form.errors -%}
        <p class="field__message field__message--error" role="alert">{{ 'general.password.error' | t }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>

  {%- if section.settings.show_newsletter -%}
    <div class="password-page__newsletter">
      {% section 'newsletter' %}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Falls back to the shop name if left blank."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Message",
      "default": "Something beautiful is coming."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    }
  ]
}
{% endschema %}
