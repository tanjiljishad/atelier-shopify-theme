{%- comment -%}
  Product page (spec §7). Composes every primitive built across Milestones
  2–6 plus this milestone's new gallery/buy-box/accordions/trust-badges
  components — see CHANGELOG.md for the full file-by-file breakdown. Order on
  the page follows spec exactly: gallery+buy-box split, bundle/cross-sell,
  recommendations, reviews, recently viewed, with the mobile sticky ATC bar
  layered on top throughout.

  Blocks: "Complete the look" products and the Reviews app slot are both
  merchant-configured blocks, but always render in their spec-mandated
  position on the page regardless of the order blocks are arranged in the
  theme editor — that order is a content decision (which products, which
  review app), not a layout one.
{%- endcomment -%}
{%- liquid
  assign bundle_product_list = '' | split: ','
  assign app_blocks = '' | split: ','
  for block in section.blocks
    case block.type
      when 'complete_the_look_item'
        if block.settings.product != blank and block.settings.product.available
          assign bundle_product_list = bundle_product_list | concat: block.settings.product
        endif
      when '@app'
        assign app_blocks = app_blocks | concat: block
    endcase
  endfor
-%}
<div class="container container--wide">
  {% render 'breadcrumb', product: product %}
</div>

<section class="section">
  <div class="container container--wide product-layout">
    <div class="product-layout__gallery">
      {% render 'product-gallery', product: product %}
    </div>
    <div class="product-layout__buybox">
      {% render 'buy-box', product: product, section: section %}
    </div>
  </div>
</section>

{%- comment -%} spec §7: "2–3 items" — a lone item isn't a bundle. {%- endcomment -%}
{%- if bundle_product_list.size >= 2 -%}
  <section class="section section--rhythm section--bg-card">
    <div class="container container--wide">
      {% render 'complete-the-look', products: bundle_product_list %}
    </div>
  </section>
{%- endif -%}

{% render 'product-recommendations', product: product %}

{%- if app_blocks.size > 0 -%}
  <section class="section section--rhythm" id="Reviews-{{ section.id }}">
    <div class="container container--wide">
      {%- for block in app_blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{%- if settings.product_show_recently_viewed -%}
  <section class="section section--rhythm">
    <div class="container container--wide">
      {% render 'recently-viewed', product: product %}
    </div>
  </section>
{%- endif -%}

{% render 'sticky-add-to-cart', product: product %}

{% schema %}
{
  "name": "Product page",
  "settings": [],
  "blocks": [
    {
      "type": "complete_the_look_item",
      "name": "Complete the look: item",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
