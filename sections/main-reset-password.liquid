{%- comment -%}
  Set a new password after following the emailed recovery link. Unlike
  create_customer, this form has a real server-side password_confirmation
  check, so both fields are required here.
{%- endcomment -%}
<div class="container customer-form-page">
  <div class="customer-form-page__header">
    <h1 class="customer-form-page__title">{{ 'customer.reset_title' | t }}</h1>
    {%- if email -%}
      <p class="text-small">{{ 'customer.reset_intro' | t: email: email }}</p>
    {%- endif -%}
  </div>

  {%- form 'reset_customer_password', class: 'customer-form' -%}
    {%- if form.errors -%}
      <p class="field__message field__message--error" role="alert">{{ form.errors.messages.first }}</p>
    {%- endif -%}

    {% render 'password-field', id: 'ResetPassword', name: 'customer[password]', label: 'customer.new_password' | t, autocomplete: 'new-password', required: true %}
    {% render 'password-field', id: 'ResetPasswordConfirm', name: 'customer[password_confirmation]', label: 'customer.confirm_password' | t, autocomplete: 'new-password', required: true %}

    <button type="submit" class="btn btn--primary btn--full">{{ 'customer.reset_submit' | t }}</button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Reset password",
  "settings": []
}
{% endschema %}
