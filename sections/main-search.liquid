<section class="section">
  <div class="page-width">
    <h1>{{ 'general.search' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products">
      <button class="button" type="submit">Search</button>
    </form>

    {% if search.performed %}
      <div class="product-grid">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card', product: item %}
          {% else %}
            <article>
              <h2><a href="{{ item.url }}">{{ item.title }}</a></h2>
              <p>{{ item.content | strip_html | truncate: 120 }}</p>
            </article>
          {% endif %}
        {% else %}
          <p>No results found.</p>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
