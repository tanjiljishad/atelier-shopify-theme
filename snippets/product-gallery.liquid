{%- comment -%}
  Product gallery (spec §5.4, §7): one <product-gallery> custom element, one
  list of media in the DOM — desktop lays it out as a vertical stacked scroll
  column (thumbnail rail alongside for quick-jump), mobile switches the exact
  same markup to a horizontal swipe carousel with dot progress, purely via CSS
  media queries. Same "one source of truth, CSS repositions" trick as
  collection-filters.liquid's sidebar/drawer split — no separate desktop/mobile
  markup to keep in sync, no JS branch on viewport width.

  Swipe/scroll on both axes is native browser scroll-snap (see product-slider.js's
  same philosophy) — assets/product-gallery.js only adds: thumbnail-click
  scrollIntoView, scrollspy (active thumb/dot follows scroll position），
  arrow-key navigation, and the zoom-button → lightbox handoff.

  Accepts: product (required).
{%- endcomment -%}
{%- liquid
  assign gallery_ratio = settings.product_gallery_image_ratio
  assign thumb_position = settings.product_gallery_thumbnail_position
  assign media_list = product.media
  assign selected_variant = product.selected_or_first_available_variant
-%}
<product-gallery
  class="product-gallery product-gallery--thumbs-{{ thumb_position }}"
  data-variant-media-id="{{ selected_variant.featured_media.id }}"
>
  <div class="product-gallery__main" data-gallery-main tabindex="0" role="group" aria-label="{{ 'products.product.gallery.label' | t }}" aria-roledescription="carousel">
    {%- if media_list.size > 0 -%}
      {%- for media in media_list -%}
        <div
          class="product-gallery__item{% unless gallery_ratio == 'natural' %} aspect-ratio{% endunless %}"
          {% unless gallery_ratio == 'natural' %}style="aspect-ratio: {{ gallery_ratio }};"{% endunless %}
          data-gallery-item
          data-media-index="{{ forloop.index0 }}"
          data-media-id="{{ media.id }}"
          role="group"
          aria-roledescription="slide"
          aria-label="{{ 'products.product.gallery.slide_label' | t: index: forloop.index, total: media_list.size }}"
        >
          {% render 'product-media-item', media: media, priority: forloop.first, context: 'gallery' %}
          {%- if media.media_type == 'image' -%}
            <button type="button" class="product-gallery__zoom-trigger" data-gallery-zoom data-media-index="{{ forloop.index0 }}" aria-label="{{ 'products.product.gallery.zoom' | t }}">
              {% render 'icon', name: 'maximize', size: 18 %}
            </button>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="product-gallery__item aspect-ratio" style="aspect-ratio: {{ gallery_ratio | default: '4/5' }};">
        {% render 'responsive-image', image: blank, wrap: false %}
      </div>
    {%- endif -%}
  </div>

  {%- if media_list.size > 1 -%}
    <div class="product-gallery__thumbs" data-gallery-thumbs role="tablist" aria-label="{{ 'products.product.gallery.thumbnails' | t }}">
      {%- for media in media_list -%}
        <button
          type="button"
          class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
          data-gallery-thumb
          data-media-index="{{ forloop.index0 }}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="{{ 'products.product.gallery.view_media' | t: index: forloop.index }}"
        >
          {% render 'product-media-item', media: media, context: 'thumbnail', aspect_ratio: gallery_ratio %}
        </button>
      {%- endfor -%}
    </div>

    <div class="product-gallery__dots" data-gallery-dots aria-hidden="true">
      {%- for media in media_list -%}
        <span class="product-gallery__dot{% if forloop.first %} is-active{% endif %}" data-gallery-dot data-media-index="{{ forloop.index0 }}"></span>
      {%- endfor -%}
    </div>
  {%- endif -%}
</product-gallery>

{% render 'product-lightbox', product: product %}
