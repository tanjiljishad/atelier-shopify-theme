{%- comment -%}
  Renders font preloads + @font-face declarations for the theme.

  Two modes, controlled by settings.use_custom_typography:
  - true  (default): self-hosted Marcellus + Instrument Sans, woff2, font-display: swap.
  - false: merchant-chosen fonts via Shopify's font_picker (settings.type_header_font /
    settings.type_body_font), served from Shopify's font CDN.

  Only the "latin" subset is preloaded (covers the vast majority of storefronts). The
  "latin-ext" @font-face rule is still declared so accented Western-European characters
  (é, ñ, ü, etc.) render correctly, but it downloads on demand via unicode-range rather
  than being preloaded, so English-only stores never pay for it.
{%- endcomment -%}

{%- if settings.use_custom_typography -%}
  {{ 'marcellus-latin-400.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous' }}
  {{ 'instrument-sans-latin-variable.woff2' | asset_url | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous' }}

  <style>
    @font-face {
      font-family: 'Marcellus';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('{{ 'marcellus-latin-400.woff2' | asset_url }}') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }

    @font-face {
      font-family: 'Marcellus';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('{{ 'marcellus-latin-ext-400.woff2' | asset_url }}') format('woff2');
      unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
    }

    @font-face {
      font-family: 'Instrument Sans';
      font-style: normal;
      font-weight: 400 600;
      font-display: swap;
      src: url('{{ 'instrument-sans-latin-variable.woff2' | asset_url }}') format('woff2-variations'), url('{{ 'instrument-sans-latin-variable.woff2' | asset_url }}') format('woff2');
      unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }

    @font-face {
      font-family: 'Instrument Sans';
      font-style: normal;
      font-weight: 400 600;
      font-display: swap;
      src: url('{{ 'instrument-sans-latin-ext-variable.woff2' | asset_url }}') format('woff2-variations'), url('{{ 'instrument-sans-latin-ext-variable.woff2' | asset_url }}') format('woff2');
      unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+1E00-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
    }
  </style>
{%- else -%}
  {%- if settings.type_header_font -%}
    {{ settings.type_header_font | font_url | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous' }}
  {%- endif -%}
  {%- if settings.type_body_font and settings.type_body_font != settings.type_header_font -%}
    {{ settings.type_body_font | font_url | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous' }}
  {%- endif -%}

  <style>
    {{ settings.type_header_font | font_face: font_display: 'swap' }}
    {%- if settings.type_body_font != settings.type_header_font %}
    {{ settings.type_body_font | font_face: font_display: 'swap' }}
    {%- endif %}
  </style>
{%- endif -%}
